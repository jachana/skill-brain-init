# 2nd-brain — environment variables
# Copy this file to ".env" and fill in YOUR values. Never commit the real .env.

# REQUIRED — absolute path to your Obsidian vault root (the "brain").
# Windows example:  D:/Vaults/Brain
# macOS/Linux example:  /home/me/Brain
BRAIN_PATH=

# OPTIONAL — root folder the sync script auto-scans for repos containing a .brain/ folder.
# Defaults to the parent directory of BRAIN_PATH if left blank.
BRAIN_REPOS_ROOT=
